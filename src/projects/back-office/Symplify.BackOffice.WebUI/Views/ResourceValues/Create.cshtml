@model Symplify.BackOffice.Application.Features.ResourceValues.Commands.Create.CreateResourceValueCommand

@{
    ViewData["Title"] = "Resource Values Oluştur";
    string? currentCulture = Context.Request.RouteValues["culture"]?.ToString();
}

<div class="dashboard-main-body">
    <div class="card border shadow-none radius-12">
        <div class="card-header border-bottom">
            <h6 class="text-lg mb-0">Resource Values Oluştur</h6>
        </div>

        <div class="card-body">
            <form asp-action="Create" asp-route-culture="@currentCulture" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row gy-4">
            <div class="col-md-6">
                <label class="form-label" asp-for="ResourceKeyId"></label>
                <input class="form-control" asp-for="ResourceKeyId" />
                <span asp-validation-for="ResourceKeyId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="LanguageId"></label>
                <input class="form-control" asp-for="LanguageId" />
                <span asp-validation-for="LanguageId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Value"></label>
                <input class="form-control" asp-for="Value" />
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-24">
                    <a asp-action="Index" asp-route-culture="@currentCulture" class="btn btn-outline-neutral-900 radius-8 px-20 py-11">Vazgeç</a>
                    <button type="submit" class="btn btn-primary-600 radius-8 px-20 py-11">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

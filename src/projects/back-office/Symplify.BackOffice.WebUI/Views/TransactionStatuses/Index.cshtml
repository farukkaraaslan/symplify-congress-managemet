@model Symplify.BackOffice.WebUI.Models.TransactionStatuses.TransactionStatusesIndexViewModel
@inject Symplify.BackOffice.WebUI.Localization.IBackOfficeViewLocalizer L

@{
    string currentCulture = ViewContext.RouteData.Values["culture"]?.ToString() ?? "tr-TR";
    ViewData["Title"] = L.GetStringValue("BackOffice.TransactionStatuses.PageTitle");
    ViewData["TransactionStatusPhases"] = Model.Phases;
    const string controllerName = "TransactionStatuses";
    string homeUrl = Url.Action("Index", "Home", new { culture = currentCulture }) ?? $"/{currentCulture}/home/index";
    string getListUrl = Url.Action("GetList", controllerName, new { culture = currentCulture }) ?? $"/{currentCulture}/transactionstatuses/getlist";
    string getForUpdateUrl = Url.Action("GetForUpdate", controllerName, new { culture = currentCulture }) ?? $"/{currentCulture}/transactionstatuses/getforupdate";
    string reorderUrl = Url.Action("Reorder", controllerName, new { culture = currentCulture }) ?? $"/{currentCulture}/transactionstatuses/reorder";
}

@Html.AntiForgeryToken()

<div class="dashboard-main-body">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <div>
            <h6 class="fw-semibold mb-0">@L["BackOffice.TransactionStatuses.PageTitle"]</h6>
            <small class="text-neutral-500">@L["BackOffice.TransactionStatuses.PageDescription"]</small>
        </div>
        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium"><a href="@homeUrl" class="d-flex align-items-center gap-1 hover-text-primary text-neutral-600"><iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>@L["Common.Panel"]</a></li>
            <li>-</li>
            <li class="fw-medium">@L["BackOffice.TransactionStatuses.PageTitle"]</li>
        </ul>
    </div>

    <div class="alert alert-info bg-primary-50 border-primary-100 text-primary-700 d-flex align-items-start gap-3 mb-24">
        <i class="ri-information-line text-xl mt-1"></i>
        <div>
            <h6 class="text-md mb-1">@L["BackOffice.TransactionStatuses.ManagementTitle"]</h6>
            <p class="mb-0">@L["BackOffice.TransactionStatuses.ManagementDescription"]</p>
        </div>
    </div>

    <div class="card border shadow-none radius-12">
        <div class="card-header border-bottom d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <h6 class="mb-1">@L["BackOffice.TransactionStatuses.ListTitle"]</h6>
                <small class="text-neutral-500">@L["BackOffice.TransactionStatuses.ListDescription"]</small>
            </div>
            <button type="button" class="btn btn-primary-600 radius-8 px-20 py-11 d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#createTransactionStatusModal"><i class="ri-add-line"></i>@L["BackOffice.TransactionStatuses.CreateButton"]</button>
        </div>
        <div class="card-body">
            <div class="row gy-3 mb-3">
                <div class="col-12 col-md-5 col-lg-4">
                    <label for="transactionStatusPhaseFilter" class="form-label">@L["BackOffice.TransactionStatuses.Fields.Phase"]</label>
                    <select id="transactionStatusPhaseFilter" class="form-select js-transaction-status-phase-filter">
                        <option value="">Tümü</option>
                        @foreach (var phase in Model.Phases)
                        {
                            <option value="@phase.Id">@phase.DisplayText</option>
                        }
                    </select>
                    <small class="text-neutral-500 d-block mt-1">@L["BackOffice.TransactionStatuses.Validation.ReorderDifferentPhaseNotAllowed"]</small>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table bordered-table mb-0" id="transactionStatusesTable" data-source-url="@getListUrl" data-get-for-update-url="@getForUpdateUrl" data-reorder-url="@reorderUrl">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th></th>
                            <th>@L["BackOffice.TransactionStatuses.Fields.Phase"]</th>
                            <th>@L["Common.Order"]</th>
                            <th>@L["BackOffice.TransactionStatuses.Fields.Code"]</th>
                            <th>@L["Common.Name"]</th>
                            <th>@L["Common.Description"]</th>
                            <th>@L["BackOffice.TransactionStatuses.Fields.IsEditable"]</th>
                            <th>@L["BackOffice.TransactionStatuses.Fields.IsFinal"]</th>
                            <th>@L["Common.Status"]</th>
                            <th class="text-end">@L["Common.Actions"]</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_CreateTransactionStatusModal", Model.CreateTransactionStatus)
@await Html.PartialAsync("_UpdateTransactionStatusModal", Model.UpdateTransactionStatus)

<form id="deleteTransactionStatusForm" asp-controller="TransactionStatuses" asp-action="Delete" asp-route-culture="@currentCulture" method="post">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    @await Html.PartialAsync("_LocalizationScripts")
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        window.Symplify = window.Symplify || {};
        window.Symplify.TransactionStatuses = window.Symplify.TransactionStatuses || {};
        window.Symplify.TransactionStatuses.urls = { getForUpdate: '@getForUpdateUrl' };
    </script>
    <script src="~/js/shared/ajax/symplify.ajax.js" asp-append-version="true"></script>
    <script src="~/js/features/transaction-statuses/transaction-statuses.table.js" asp-append-version="true"></script>
    <script src="~/js/features/transaction-statuses/transaction-statuses.create.js" asp-append-version="true"></script>
    <script src="~/js/features/transaction-statuses/transaction-statuses.update.js" asp-append-version="true"></script>
    <script src="~/js/features/transaction-statuses/transaction-statuses.delete.js" asp-append-version="true"></script>
    <script src="~/js/features/transaction-statuses/transaction-statuses.index.js" asp-append-version="true"></script>
}

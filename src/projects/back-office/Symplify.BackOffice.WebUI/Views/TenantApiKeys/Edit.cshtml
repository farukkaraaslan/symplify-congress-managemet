@model Symplify.BackOffice.Application.Features.TenantApiKeys.Commands.Update.UpdateTenantApiKeyCommand

@{
    ViewData["Title"] = "Tenant Api Keys Düzenle";
    string? currentCulture = Context.Request.RouteValues["culture"]?.ToString();
}

<div class="dashboard-main-body">
    <div class="card border shadow-none radius-12">
        <div class="card-header border-bottom">
            <h6 class="text-lg mb-0">Tenant Api Keys Düzenle</h6>
        </div>

        <div class="card-body">
            <form asp-action="Edit" asp-route-culture="@currentCulture" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row gy-4">
            <input asp-for="Id" type="hidden" />
            <div class="col-md-6">
                <label class="form-label" asp-for="TenantId"></label>
                <input class="form-control" asp-for="TenantId" />
                <span asp-validation-for="TenantId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Name"></label>
                <input class="form-control" asp-for="Name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="KeyPrefix"></label>
                <input class="form-control" asp-for="KeyPrefix" />
                <span asp-validation-for="KeyPrefix" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="KeyHash"></label>
                <input class="form-control" asp-for="KeyHash" />
                <span asp-validation-for="KeyHash" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="ExpiresAt"></label>
                <input class="form-control" asp-for="ExpiresAt" type="datetime-local" />
                <span asp-validation-for="ExpiresAt" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="LastUsedAt"></label>
                <input class="form-control" asp-for="LastUsedAt" type="datetime-local" />
                <span asp-validation-for="LastUsedAt" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label d-block" asp-for="IsActive"></label>
                <input type="hidden" name="IsActive" value="false" />
                <div class="form-check form-switch">
                    <input class="form-check-input" asp-for="IsActive" value="true" />
                    <label class="form-check-label" asp-for="IsActive"></label>
                </div>
                <span asp-validation-for="IsActive" class="text-danger"></span>
            </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-24">
                    <a asp-action="Index" asp-route-culture="@currentCulture" class="btn btn-outline-neutral-900 radius-8 px-20 py-11">Vazgeç</a>
                    <button type="submit" class="btn btn-primary-600 radius-8 px-20 py-11">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

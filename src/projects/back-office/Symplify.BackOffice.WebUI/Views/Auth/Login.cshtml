@model Symplify.BackOffice.WebUI.Models.Auth.LoginViewModel
@{
    Layout = null;
    string culture = ViewContext.RouteData.Values["culture"]?.ToString() ?? "tr-TR";
}
<!DOCTYPE html>
<html lang="@culture" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giriş - Symplify BackOffice</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/style.css" rel="stylesheet" />
</head>
<body>
    <main class="min-vh-100 bg-neutral-50 px-16 position-relative">
        <div class="position-absolute top-0 end-0 p-24">
            @await Component.InvokeAsync("LanguageSwitcher")
        </div>

        <div class="min-vh-100 d-flex align-items-center justify-content-center">
            <div class="card border shadow-none radius-12 w-100" style="max-width: 460px;">
                <div class="card-body p-32">
                    <div class="text-center mb-24">
                        <h5 class="mb-1">Symplify BackOffice</h5>
                        <p class="text-neutral-500 mb-0">Yönetim paneline giriş yapın.</p>
                    </div>

                    <form asp-action="Login" asp-controller="Auth" asp-route-culture="@culture" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-20">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" autocomplete="username" placeholder="admin@symplify.com" />
                            <span asp-validation-for="Email" class="text-danger text-sm"></span>
                        </div>

                        <div class="mb-20">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Şifrenizi giriniz" />
                            <span asp-validation-for="Password" class="text-danger text-sm"></span>
                        </div>

                        <div class="form-check mb-24">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <button type="submit" class="btn btn-primary-600 w-100 radius-8 py-11 d-inline-flex align-items-center justify-content-center gap-2">
                            <i class="ri-login-circle-line"></i>
                            Giriş Yap
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>
</body>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</html>

@model Symplify.BackOffice.Application.Features.PaymentDocuments.Commands.Update.UpdatePaymentDocumentCommand

@{
    ViewData["Title"] = "Payment Documents Düzenle";
    string? currentCulture = Context.Request.RouteValues["culture"]?.ToString();
}

<div class="dashboard-main-body">
    <div class="card border shadow-none radius-12">
        <div class="card-header border-bottom">
            <h6 class="text-lg mb-0">Payment Documents Düzenle</h6>
        </div>

        <div class="card-body">
            <form asp-action="Edit" asp-route-culture="@currentCulture" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row gy-4">
            <input asp-for="Id" type="hidden" />
            <div class="col-md-6">
                <label class="form-label" asp-for="SubmissionId"></label>
                <input class="form-control" asp-for="SubmissionId" />
                <span asp-validation-for="SubmissionId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="CongressId"></label>
                <input class="form-control" asp-for="CongressId" />
                <span asp-validation-for="CongressId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="FilePath"></label>
                <input class="form-control" asp-for="FilePath" />
                <span asp-validation-for="FilePath" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="OriginalFileName"></label>
                <input class="form-control" asp-for="OriginalFileName" />
                <span asp-validation-for="OriginalFileName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="ContentType"></label>
                <input class="form-control" asp-for="ContentType" />
                <span asp-validation-for="ContentType" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Size"></label>
                <input class="form-control" asp-for="Size" type="number" />
                <span asp-validation-for="Size" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label d-block" asp-for="IsApproved"></label>
                <input type="hidden" name="IsApproved" value="false" />
                <div class="form-check form-switch">
                    <input class="form-check-input" asp-for="IsApproved" value="true" />
                    <label class="form-check-label" asp-for="IsApproved"></label>
                </div>
                <span asp-validation-for="IsApproved" class="text-danger"></span>
            </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-24">
                    <a asp-action="Index" asp-route-culture="@currentCulture" class="btn btn-outline-neutral-900 radius-8 px-20 py-11">Vazgeç</a>
                    <button type="submit" class="btn btn-primary-600 radius-8 px-20 py-11">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

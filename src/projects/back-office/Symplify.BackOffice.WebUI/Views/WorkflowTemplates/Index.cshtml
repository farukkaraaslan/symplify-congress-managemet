@model Symplify.BackOffice.WebUI.Models.WorkflowTemplates.WorkflowTemplatesIndexViewModel
@inject Symplify.BackOffice.WebUI.Localization.IBackOfficeViewLocalizer L

@{
    string currentCulture = ViewContext.RouteData.Values["culture"]?.ToString() ?? "tr-TR";
    ViewData["Title"] = L.GetStringValue("BackOffice.WorkflowTemplates.PageTitle");
    ViewData["InitialStatuses"] = Model.InitialStatuses;

    const string controllerName = "WorkflowTemplates";
    const string featureName = "workflow-templates";

    string homeUrl = Url.Action("Index", "Home", new { culture = currentCulture }) ?? $"/{currentCulture}/home/index";
    string getListUrl = Url.Action("GetList", controllerName, new { culture = currentCulture }) ?? $"/{currentCulture}/workflowtemplates/getlist";
    string getForUpdateUrl = Url.Action("GetForUpdate", controllerName, new { culture = currentCulture }) ?? $"/{currentCulture}/workflowtemplates/getforupdate";
    string transitionIndexBaseUrl = Url.Action("Index", "WorkflowTemplateTransitions", new { culture = currentCulture }) ?? $"/{currentCulture}/workflowtemplatetransitions/index";
}

@Html.AntiForgeryToken()

<div class="dashboard-main-body">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <div>
            <h6 class="fw-semibold mb-0">@L["BackOffice.WorkflowTemplates.PageTitle"]</h6>
            <small class="text-neutral-500">@L["BackOffice.WorkflowTemplates.PageDescription"]</small>
        </div>

        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium">
                <a href="@homeUrl" class="d-flex align-items-center gap-1 hover-text-primary text-neutral-600">
                    <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                    @L["Common.Panel"]
                </a>
            </li>
            <li>-</li>
            <li class="fw-medium">@L["BackOffice.WorkflowTemplates.PageTitle"]</li>
        </ul>
    </div>

    <div class="alert alert-info bg-primary-50 border-primary-100 text-primary-700 d-flex align-items-start gap-3 mb-24">
        <i class="ri-information-line text-xl mt-1"></i>
        <div>
            <h6 class="text-md mb-1">@L["BackOffice.WorkflowTemplates.ManagementTitle"]</h6>
            <p class="mb-0">@L["BackOffice.WorkflowTemplates.ManagementDescription"]</p>
        </div>
    </div>

    <div class="card border shadow-none radius-12">
        <div class="card-header border-bottom d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <h6 class="mb-1">@L["BackOffice.WorkflowTemplates.ListTitle"]</h6>
                <small class="text-neutral-500">@L["BackOffice.WorkflowTemplates.ListDescription"]</small>
            </div>

            <button type="button"
                    class="btn btn-primary-600 radius-8 px-20 py-11 d-flex align-items-center gap-2"
                    data-bs-toggle="modal"
                    data-bs-target="#createWorkflowTemplateModal">
                <i class="ri-add-line"></i>
                @L["BackOffice.WorkflowTemplates.CreateButton"]
            </button>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table bordered-table mb-0 js-workflow-template-table"
                       id="workflowTemplatesTable"
                       data-feature="@featureName"
                       data-source-url="@getListUrl"
                       data-get-for-update-url="@getForUpdateUrl"
                       data-transition-index-url="@transitionIndexBaseUrl">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>@L["Common.Code"]</th>
                            <th>@L["Common.Name"]</th>
                            <th>@L["Common.Description"]</th>
                            <th>@L["BackOffice.WorkflowTemplates.InitialTransactionStatus"]</th>
                            <th>@L["BackOffice.WorkflowTemplates.IsDefault"]</th>
                            <th>@L["Common.Status"]</th>
                            <th class="text-end">@L["Common.Actions"]</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_CreateWorkflowTemplateModal", Model.CreateWorkflowTemplate)
@await Html.PartialAsync("_UpdateWorkflowTemplateModal", Model.UpdateWorkflowTemplate)

<form id="deleteWorkflowTemplateForm" asp-controller="WorkflowTemplates" asp-action="Delete" asp-route-culture="@currentCulture" method="post">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    @await Html.PartialAsync("_LocalizationScripts")
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        window.Symplify = window.Symplify || {};
        window.Symplify.WorkflowTemplates = window.Symplify.WorkflowTemplates || {};
        window.Symplify.WorkflowTemplates.urls = {
            getForUpdate: '@getForUpdateUrl',
            transitionIndex: '@transitionIndexBaseUrl'
        };
    </script>

    <script src="~/js/shared/ajax/symplify.ajax.js" asp-append-version="true"></script>
    <script src="~/js/features/workflow-templates/workflow-templates.table.js" asp-append-version="true"></script>
    <script src="~/js/features/workflow-templates/workflow-templates.create.js" asp-append-version="true"></script>
    <script src="~/js/features/workflow-templates/workflow-templates.update.js" asp-append-version="true"></script>
    <script src="~/js/features/workflow-templates/workflow-templates.delete.js" asp-append-version="true"></script>
    <script src="~/js/features/workflow-templates/workflow-templates.index.js" asp-append-version="true"></script>
}

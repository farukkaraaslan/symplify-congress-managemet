@model Symplify.BackOffice.Application.Features.CongressEvaluationCriteria.Queries.GetById.GetByIdCongressEvaluationCriterionResponse
@using System.Reflection

@{
    ViewData["Title"] = "Congress Evaluation Criteria Detay";
    string? currentCulture = Context.Request.RouteValues["culture"]?.ToString();
    PropertyInfo[] properties = typeof(Symplify.BackOffice.Application.Features.CongressEvaluationCriteria.Queries.GetById.GetByIdCongressEvaluationCriterionResponse).GetProperties();
}

<div class="dashboard-main-body">
    <div class="card border shadow-none radius-12">
        <div class="card-header border-bottom d-flex align-items-center justify-content-between">
            <h6 class="text-lg mb-0">Congress Evaluation Criteria Detay</h6>
            <a asp-action="Index" asp-route-culture="@currentCulture" class="btn btn-outline-neutral-900 radius-8 px-20 py-11">Listeye Dön</a>
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                @foreach (PropertyInfo property in properties)
                {
                    <dt class="col-sm-3">@property.Name</dt>
                    <dd class="col-sm-9">@(property.GetValue(Model) ?? "-")</dd>
                }
            </dl>
        </div>
    </div>
</div>

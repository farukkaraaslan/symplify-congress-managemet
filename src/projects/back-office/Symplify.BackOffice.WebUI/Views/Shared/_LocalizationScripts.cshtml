@inject Symplify.BackOffice.WebUI.Localization.IBackOfficeViewLocalizer L
@{
    string T(string key, string fallback)
    {
        string value = L.GetStringValue(key);
        return string.IsNullOrWhiteSpace(value) || string.Equals(value, key, StringComparison.OrdinalIgnoreCase)
            ? fallback
            : value;
    }

    string Js(string key, string fallback)
    {
        return System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(T(key, fallback));
    }
}

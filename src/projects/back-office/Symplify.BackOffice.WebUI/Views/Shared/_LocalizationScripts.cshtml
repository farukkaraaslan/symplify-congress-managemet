@inject Symplify.BackOffice.WebUI.Localization.IClientResourceService ClientResources
@{
    static IEnumerable<string> ResolvePrefixObject(object? value)
    {
        if (value is null)
            return Enumerable.Empty<string>();

        if (value is string singlePrefix)
            return new[] { singlePrefix };

        if (value is IEnumerable<string> stringPrefixes)
            return stringPrefixes;

        if (value is IEnumerable<object> objectPrefixes)
            return objectPrefixes
                .Select(item => item?.ToString())
                .Where(item => !string.IsNullOrWhiteSpace(item))
                .Select(item => item!);

        return Enumerable.Empty<string>();
    }
    static string? NormalizePrefix(string? prefix)
    {
        if (string.IsNullOrWhiteSpace(prefix))
            return null;

        string normalizedPrefix = prefix.Trim();

        return normalizedPrefix.EndsWith(".", StringComparison.Ordinal)
            ? normalizedPrefix
            : $"{normalizedPrefix}.";
    }

    string? controllerName = ViewContext.RouteData.Values["controller"]?.ToString();

    List<string> resourcePrefixes = new[]
        {
            "Common.",
            "Common.DataTable.",
            "BackOffice.Sidebar."
        }
        .Concat(ResolvePrefixObject(ViewData["ClientResourcePrefixes"]))
        .ToList();

    if (!string.IsNullOrWhiteSpace(controllerName))
        resourcePrefixes.Add($"BackOffice.{controllerName}.");

    resourcePrefixes = resourcePrefixes
        .Select(NormalizePrefix)
        .Where(prefix => !string.IsNullOrWhiteSpace(prefix))
        .Select(prefix => prefix!)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(prefix => prefix, StringComparer.OrdinalIgnoreCase)
        .ToList();

    IReadOnlyDictionary<string, string> localizedResources = await ClientResources.GetResourcesAsync(
        resourcePrefixes,
        Context.RequestAborted);

    string resourcesJson = System.Text.Json.JsonSerializer.Serialize(
        localizedResources,
        new System.Text.Json.JsonSerializerOptions
        {
            Encoder = System.Text.Encodings.Web.JavaScriptEncoder.Default
        });
}
<script>
    window.Symplify = window.Symplify || {};

    window.Symplify.resources = window.Symplify.resources || {};
    Object.assign(window.Symplify.resources, @Html.Raw(resourcesJson));

    window.Symplify.t = function (key, fallback) {
        const resources = window.Symplify.resources || {};
        const value = resources[key];

        if (value && value !== key) {
            return value;
        }

        return fallback || key;
    };

    window.Symplify.texts = Object.assign(window.Symplify.texts || {}, {
        ok: window.Symplify.t("Common.Ok", "Tamam"),
        cancel: window.Symplify.t("Common.Cancel", "Vazgeç"),
        close: window.Symplify.t("Common.Close", "Kapat"),
        save: window.Symplify.t("Common.Save", "Kaydet"),
        active: window.Symplify.t("Common.Active", "Aktif"),
        passive: window.Symplify.t("Common.Passive", "Pasif"),
        edit: window.Symplify.t("Common.Edit", "Düzenle"),
        delete: window.Symplify.t("Common.Delete", "Sil"),
        errorTitle: window.Symplify.t("Common.Error", "Hata"),
        successTitle: window.Symplify.t("Common.Success", "Başarılı"),
        genericError: window.Symplify.t("Common.GenericError", "İşlem sırasında bir hata oluştu."),
        invalidRequest: window.Symplify.t("Common.InvalidRequest", "Geçersiz istek."),
        created: window.Symplify.t("Common.Created", "Kayıt oluşturuldu."),
        updated: window.Symplify.t("Common.Updated", "Kayıt güncellendi."),
        deleted: window.Symplify.t("Common.Deleted", "Kayıt silindi."),
        deleteConfirmTitle: window.Symplify.t("Common.DeleteConfirmTitle", "Silmek istediğinize emin misiniz?"),
        deleteConfirmText: window.Symplify.t("Common.DeleteConfirmText", "Bu kayıt silinecek. Silme sonrası aktif kayıtların sıra numarası otomatik düzenlenecek."),
        deleteConfirmButton: window.Symplify.t("Common.DeleteConfirmButton", "Sil"),
        order: window.Symplify.t("Common.Order", "Sıra"),
        name: window.Symplify.t("Common.Name", "Ad"),
        description: window.Symplify.t("Common.Description", "Açıklama"),
        status: window.Symplify.t("Common.Status", "Durum"),
        actions: window.Symplify.t("Common.Actions", "İşlemler"),
        code: window.Symplify.t("Common.Code", "Kod"),
        systemKey: window.Symplify.t("Common.SystemKey", "Sistem Anahtarı"),
        yes: window.Symplify.t("Common.Yes", "Evet"),

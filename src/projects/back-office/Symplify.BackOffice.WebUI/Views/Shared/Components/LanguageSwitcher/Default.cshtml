@model Symplify.BackOffice.WebUI.Models.LanguageSwitcher.LanguageSwitcherViewModel

@{
    string currentCulture = Model.CurrentLanguage?.Culture ?? Model.CurrentCulture;
    string currentLanguageName = Model.CurrentLanguage?.Name ?? currentCulture;
    string currentTwoLetterIsoCode = Model.CurrentLanguage?.TwoLetterIsoCode ?? currentCulture[..2];
}

<div class="dropdown d-none d-sm-inline-block">
    <button class="navbar-action-btn has-indicator w-40-px h-40-px bg-neutral-200 rounded-circle d-flex justify-content-center align-items-center"
            type="button"
            data-bs-toggle="dropdown"
            aria-label="@currentLanguageName">
        <span class="text-sm fw-semibold">@currentCulture</span>
    </button>

    <div class="dropdown-menu dropdown-menu-sm">
        <div class="py-12 px-16 radius-8 bg-primary-50 mb-16 d-flex align-items-center justify-content-between gap-2">
            <div>
                <h6 class="text-lg text-primary-light fw-semibold mb-0">@currentLanguageName</h6>
            </div>
        </div>

        <div class="max-h-400-px overflow-y-auto scroll-sm pe-8">
            @foreach (var language in Model.Languages)
            {
                string twoLetterIsoCode = string.IsNullOrWhiteSpace(language.TwoLetterIsoCode)
                    ? language.Culture[..2]
                    : language.TwoLetterIsoCode;

                <a class="dropdown-item text-black px-0 py-8 hover-bg-transparent hover-text-primary d-flex align-items-center justify-content-between gap-3 @(language.IsCurrent ? "active" : string.Empty)"
                       href="@language.Url">
                    <span class="d-flex align-items-center gap-3">
                        <span class="w-36-px h-36-px bg-success-subtle text-success-main rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center text-uppercase">
                            @twoLetterIsoCode
                        </span>
                        <span class="text-md fw-semibold mb-0">@language.Name</span>
                    </span>

                    @if (language.IsCurrent)
                    {
                        <i class="ri-check-line text-primary-600"></i>
                    }
                </a>
            }
        </div>
    </div>
</div>
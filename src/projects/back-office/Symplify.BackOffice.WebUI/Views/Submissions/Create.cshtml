@model Symplify.BackOffice.Application.Features.Submissions.Commands.Create.CreateSubmissionCommand

@{
    ViewData["Title"] = "Submissions Oluştur";
    string? currentCulture = Context.Request.RouteValues["culture"]?.ToString();
}

<div class="dashboard-main-body">
    <div class="card border shadow-none radius-12">
        <div class="card-header border-bottom">
            <h6 class="text-lg mb-0">Submissions Oluştur</h6>
        </div>

        <div class="card-body">
            <form asp-action="Create" asp-route-culture="@currentCulture" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row gy-4">
            <div class="col-md-6">
                <label class="form-label" asp-for="CongressId"></label>
                <input class="form-control" asp-for="CongressId" />
                <span asp-validation-for="CongressId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="SubmissionTypeId"></label>
                <input class="form-control" asp-for="SubmissionTypeId" />
                <span asp-validation-for="SubmissionTypeId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="TopicId"></label>
                <input class="form-control" asp-for="TopicId" />
                <span asp-validation-for="TopicId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="CreatedByUserId"></label>
                <input class="form-control" asp-for="CreatedByUserId" />
                <span asp-validation-for="CreatedByUserId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="PaymentStatusId"></label>
                <input class="form-control" asp-for="PaymentStatusId" type="number" />
                <span asp-validation-for="PaymentStatusId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="TransactionStatusId"></label>
                <input class="form-control" asp-for="TransactionStatusId" type="number" />
                <span asp-validation-for="TransactionStatusId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Title"></label>
                <input class="form-control" asp-for="Title" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Abstract"></label>
                <input class="form-control" asp-for="Abstract" />
                <span asp-validation-for="Abstract" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Keywords"></label>
                <input class="form-control" asp-for="Keywords" />
                <span asp-validation-for="Keywords" class="text-danger"></span>
            </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-24">
                    <a asp-action="Index" asp-route-culture="@currentCulture" class="btn btn-outline-neutral-900 radius-8 px-20 py-11">Vazgeç</a>
                    <button type="submit" class="btn btn-primary-600 radius-8 px-20 py-11">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
